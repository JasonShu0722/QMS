# 应用配置
APP_NAME="QMS Quality Management System"
APP_VERSION="1.0.0"
ENVIRONMENT=stable
DEBUG=False

# 数据库配置
DATABASE_URL=postgresql+asyncpg://qms_user:your_db_password@postgres:5432/qms_db
DB_ECHO=False

# Redis 配置
REDIS_URL=redis://redis:6379/0

# JWT 认证配置
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
PLATFORM_ADMIN_USERNAMES=admin

# 密码策略
PASSWORD_MIN_LENGTH=8
PASSWORD_EXPIRE_DAYS=90
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# LDAP 配置（预留 SSO 集成）
LDAP_ENABLED=False
LDAP_SERVER=ldap://your-ldap-server:389
LDAP_BASE_DN=dc=company,dc=com
LDAP_BIND_DN=cn=admin,dc=company,dc=com
LDAP_BIND_PASSWORD=your_ldap_password

# IMS 系统集成
IMS_BASE_URL=http://ims-internal-server/api
IMS_API_KEY=your_ims_api_key
IMS_TIMEOUT=30

# SMTP 邮件配置
SMTP_SERVER=smtp.company.com
SMTP_PORT=587
SMTP_USERNAME=qms@company.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=qms@company.com
SMTP_USE_TLS=True

# Celery 任务队列
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# 文件上传
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# CORS 配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://qms.company.com","https://preview.company.com"]

# OpenAI API（AI 诊断功能）
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
