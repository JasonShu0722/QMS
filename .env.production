# QMS production environment

# Database
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql+asyncpg://qms_user:${DB_PASSWORD}@postgres:5432/qms_db

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Security
SECRET_KEY=CHANGE_ME_GENERATE_STRONG_SECRET_KEY_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
PASSWORD_MIN_LENGTH=8
PASSWORD_EXPIRE_DAYS=90
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# Application
ENVIRONMENT=stable
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["https://qms.bigshuaibee.cn","https://preview.qms.bigshuaibee.cn","http://qms.bigshuaibee.cn","http://preview.qms.bigshuaibee.cn"]
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=52428800

# Domain
PRIMARY_DOMAIN=qms.bigshuaibee.cn
PREVIEW_DOMAIN=preview.qms.bigshuaibee.cn
PRIMARY_CERT_FILE=qms.bigshuaibee.cn.crt
PRIMARY_KEY_FILE=qms.bigshuaibee.cn.key
PREVIEW_CERT_FILE=preview.qms.bigshuaibee.cn.crt
PREVIEW_KEY_FILE=preview.qms.bigshuaibee.cn.key

# Host port binding for Nginx Proxy Manager
QMS_BIND_IP=127.0.0.1
QMS_NGINX_PORT=8081
BACKEND_STABLE_PORT=8000
BACKEND_PREVIEW_PORT=8001

# Integrations
IMS_BASE_URL=http://internal-ims.company.local:8080
IMS_API_KEY=CHANGE_ME_IMS_API_KEY
IMS_TIMEOUT=30
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

SMTP_SERVER=smtp.company.com
SMTP_PORT=587
SMTP_USERNAME=qms@company.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=qms@company.com

LDAP_ENABLED=false

# Celery
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2
