# Database Configuration
DB_PASSWORD=your_secure_database_password_here
DATABASE_URL=postgresql+asyncpg://qms_user:${DB_PASSWORD}@postgres:5432/qms_db

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# JWT Authentication
SECRET_KEY=your_jwt_secret_key_minimum_32_characters_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# IMS System Integration (Internal Management System)
IMS_BASE_URL=http://internal-ims-server/api
IMS_API_KEY=your_ims_api_key_here

# AI Integration (OpenAI Compatible)
OPENAI_API_KEY=your_openai_or_deepseek_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# Email Configuration (SMTP)
SMTP_SERVER=smtp.company.com
SMTP_PORT=587
SMTP_USERNAME=qms@company.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_EMAIL=qms@company.com
SMTP_FROM_NAME=QMS质量管理系统

# Environment Configuration
ENVIRONMENT=stable  # Options: stable, preview

# LDAP/AD Configuration (Reserved for Phase 2)
LDAP_SERVER=ldap://ad.company.com
LDAP_BASE_DN=dc=company,dc=com
LDAP_BIND_USER=cn=qms_service,ou=services,dc=company,dc=com
LDAP_BIND_PASSWORD=your_ldap_bind_password_here

# Application Configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","https://qms.company.com","https://preview.company.com"]
LOG_LEVEL=INFO

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=/app/uploads

# Celery Configuration
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2
