# QMS Production Environment Configuration
# 生产环境配置文件

# ============================================
# Database Configuration (数据库配置)
# ============================================
DATABASE_URL=postgresql+asyncpg://qms_user:${DB_PASSWORD}@postgres:5432/qms_db
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ============================================
# Redis Configuration (Redis 配置)
# ============================================
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# ============================================
# Security Configuration (安全配置)
# ============================================
SECRET_KEY=CHANGE_ME_GENERATE_STRONG_SECRET_KEY_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# Password Policy (密码策略)
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_EXPIRY_DAYS=90
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# ============================================
# Application Configuration (应用配置)
# ============================================
ENVIRONMENT=stable
DEBUG=false
LOG_LEVEL=INFO

# CORS Settings (跨域配置)
CORS_ORIGINS=https://qms.company.com,https://preview.company.com

# ============================================
# IMS Integration (IMS 系统集成)
# ============================================
IMS_BASE_URL=http://internal-ims.company.local:8080
IMS_API_KEY=CHANGE_ME_IMS_API_KEY
IMS_TIMEOUT_SECONDS=30
IMS_SYNC_SCHEDULE=0 2 * * *  # Daily at 02:00

# ============================================
# AI Integration (AI 集成)
# ============================================
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
# Alternative: DeepSeek
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# ============================================
# Email Configuration (邮件配置)
# ============================================
SMTP_SERVER=smtp.company.com
SMTP_PORT=587
SMTP_USERNAME=qms@company.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=qms@company.com
SMTP_FROM_NAME=QMS质量管理系统

# ============================================
# Enterprise Communication (企业通讯集成)
# ============================================
# WeChat Work (企业微信)
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=CHANGE_ME

# DingTalk (钉钉)
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=CHANGE_ME

# ============================================
# File Storage (文件存储)
# ============================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,xlsx,xls,doc,docx

# ============================================
# Celery Configuration (异步任务配置)
# ============================================
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=Asia/Shanghai
CELERY_ENABLE_UTC=false

# ============================================
# Performance Optimization (性能优化)
# ============================================
# Redis Cache TTL (seconds)
CACHE_USER_PERMISSIONS_TTL=3600
CACHE_FEATURE_FLAGS_TTL=300
CACHE_SYSTEM_CONFIG_TTL=600
CACHE_METRICS_TTL=1800

# Database Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================
# Monitoring & Logging (监控与日志)
# ============================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================
# Backup Configuration (备份配置)
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * *  # Daily at 03:00
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=/backups
