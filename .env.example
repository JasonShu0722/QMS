# Shared environment example for local and server usage

# Database
DB_PASSWORD=your_secure_database_password_here
DATABASE_URL=postgresql+asyncpg://qms_user:${DB_PASSWORD}@postgres:5432/qms_db

# Redis
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Auth
SECRET_KEY=your_jwt_secret_key_minimum_32_characters_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
PASSWORD_MIN_LENGTH=8
PASSWORD_EXPIRE_DAYS=90
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# IMS
IMS_BASE_URL=http://internal-ims-server/api
IMS_API_KEY=your_ims_api_key_here
IMS_TIMEOUT=30

# AI
OPENAI_API_KEY=your_openai_or_deepseek_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Mail
SMTP_SERVER=smtp.company.com
SMTP_PORT=587
SMTP_USERNAME=qms@company.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_EMAIL=qms@company.com
SMTP_USE_TLS=true

# App
ENVIRONMENT=stable
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://qms.bigshuaibee.cn","https://preview.qms.bigshuaibee.cn"]
LOG_LEVEL=INFO
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=52428800

# Independent requirements panel accounts
REQ_PANEL_ADMIN_USERNAME=requirements_admin
REQ_PANEL_ADMIN_PASSWORD=ReqPanelAdmin@2026
REQ_PANEL_ADMIN_FULL_NAME=需求面板管理员
REQ_PANEL_VIEWER_USERNAME=requirements_viewer
REQ_PANEL_VIEWER_PASSWORD=ReqPanelViewer@2026
REQ_PANEL_VIEWER_FULL_NAME=需求面板查阅账号

# Domain
PRIMARY_DOMAIN=qms.bigshuaibee.cn
PREVIEW_DOMAIN=preview.qms.bigshuaibee.cn
PRIMARY_CERT_FILE=qms.bigshuaibee.cn.crt
PRIMARY_KEY_FILE=qms.bigshuaibee.cn.key
PREVIEW_CERT_FILE=preview.qms.bigshuaibee.cn.crt
PREVIEW_KEY_FILE=preview.qms.bigshuaibee.cn.key

# Host port binding
QMS_BIND_IP=127.0.0.1
QMS_NGINX_PORT=8081
BACKEND_STABLE_PORT=8000
BACKEND_PREVIEW_PORT=8001

# LDAP
LDAP_SERVER=ldap://ad.company.com
LDAP_BASE_DN=dc=company,dc=com
LDAP_BIND_DN=cn=qms_service,ou=services,dc=company,dc=com
LDAP_BIND_PASSWORD=your_ldap_bind_password_here
LDAP_ENABLED=false

# Celery
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2
